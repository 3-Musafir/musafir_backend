<p>Dear {{fullName}},</p>
</br>
<p>Your refund request for <strong>{{tripName}}</strong> was not approved.</p>
{{#if reason}}
  </br>
  <p><strong>Reason:</strong> {{reason}}</p>
{{/if}}
{{#if retryAt}}
  </br>
  <p>You can reapply after {{retryAt}}.</p>
{{else}}
  </br>
  <p>You can reapply after 24 hours.</p>
{{/if}}
{{#if refundUrl}}
  </br>
  <p>You can review your refund status here:</p>
  <p><a href="{{refundUrl}}">{{refundUrl}}</a></p>
{{/if}}
</br>
<p>Best regards,</p>
<p>The 3Musafir Team</p>
