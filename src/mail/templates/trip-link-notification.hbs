<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#f5f7fb; padding:24px 0;">
  <tr>
    <td align="center">
      <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="max-width:600px; background:#ffffff; border:1px solid #e5e7eb; border-radius:8px; overflow:hidden;">
        <tr>
          <td bgcolor="#111827" style="color:#ffffff; padding:22px 24px;">
            <div style="font-size:14px; letter-spacing:.3px; opacity:.9;">3Musafir</div>
            <h2 style="margin:6px 0 0; font-size:24px; line-height:1.3; font-weight:800; color:#ffffff;">{{headline}}</h2>
          </td>
        </tr>
        <tr>
          <td style="padding:22px; font-size:16px; color:#111827; line-height:1.6;">
            <p style="margin:0 0 16px;">{{message}}</p>
            <a href="{{actionUrl}}" style="display:inline-block; padding:12px 18px; background:#111827; color:#ffffff; text-decoration:none; border-radius:6px; font-weight:600;">
              {{actionLabel}}
            </a>
          </td>
        </tr>
        <tr>
          <td style="padding:16px 22px; font-size:12px; color:#6b7280; border-top:1px solid #e5e7eb;">
            If you did not expect this message, you can ignore it.
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
